<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.igengine.exposurewatchdog</string>

    <!-- Autonomous correlated-exposure / pyramiding Telegram alert. Read + notify only:
         never touches the engine or any strategy/risk parameter. Independent of any
         Claude/agent session. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ziscross/.openclaw/workspace/projects/ig-trading/scripts/exposure_watchdog.sh</string>
    </array>

    <!-- Check every 5 minutes -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/ig-exposure-watchdog.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/ig-exposure-watchdog.out.log</string>
</dict>
</plist>
