# IG Trading System — Environment Variables
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# ============================================
# IG Markets API
# ============================================
IG_API_KEY=your_api_key_here
IG_IDENTIFIER=your_username_here
IG_PASSWORD=your_password_here
IG_ACCOUNT_ID=                    # Optional, auto-detected from first account
IG_ENVIRONMENT=demo               # demo | live

# ============================================
# Database
# ============================================
POSTGRES_USER=ig
POSTGRES_PASSWORD=ig_secret_change_me

# ============================================
# Redis
# ============================================
# Default: redis://redis:6379 (Docker) or redis://localhost:6379 (local)

# ============================================
# Notifications (Optional)
# ============================================
TELEGRAM_BOT_TOKEN=               # Create via @BotFather on Telegram
TELEGRAM_CHAT_ID=                 # Your chat ID (use @userinfobot)

# ============================================
# Engine
# ============================================
RUST_LOG=info                     # debug | info | warn | error
